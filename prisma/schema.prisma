// Prisma config - tells Prisma which databse to use
generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// User model - one row per user of your app

model User {
  id       String    @id @default(cuid())  //unique ID auto-generated
  email    String    @unique               // no two user same email
  name     String?                         // Optional - ? means nullable
  createdAt DateTime  @default(now())      //auto-set when created

  //relation - one user can have many threats
  threats Threat[]
}

//Threat Model  - one row per saved CVE
model Threat {
  id             String   @id @default(cuid())
  cveId          String                            //e.g. CVE-2024-21762
  score          Float       
  severity       String
  vendor         String
  description    String
  patched        Boolean @default(false)           // default unpatched
  createdAt      DateTime @default(now())

//Foreign Key - links each threat to a user

   userId        String
   user          User           @relation(fields: [userId], references: [id])

}