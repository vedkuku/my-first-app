generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Threat Model - one row per saved CVE
model Threat {
  id          String   @id @default(cuid())
  cveId       String                         // e.g. CVE-2024-21762
  score       Float
  severity    String
  vendor      String
  description String
  patched     Boolean  @default(false)       // default unpatched
  createdAt   DateTime @default(now())
  userId      String                         // Clerk userId — plain string, no FK constraint
}